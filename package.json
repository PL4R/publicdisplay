{
  "name": "public-display",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Editor + generator for a TV signage carousel: build a deck of image pages, export a standalone HTML player to disk.",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c yellow,cyan \"node server/index.js\" \"vite\"",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "express": "^4.21.2",
    "multer": "^2.0.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/bricolage-grotesque": "^5.2.5",
    "@fontsource/ibm-plex-mono": "^5.2.5",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^7.0.0"
  }
}
